@model List<Employeemanagementpractice.Models.TrainingCourse>
@{ ViewData["Title"] = "Training Center"; var progress = ViewBag.Progress as List<Employeemanagementpractice.Models.TrainingProgress> ?? new(); var stats = ViewBag.Stats; }

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h4 class="fw-bold mb-0" style="font-size:1.1rem;"><i class="fas fa-graduation-cap text-primary me-2"></i>Training Center</h4>
        <p class="text-muted mb-0" style="font-size:0.73rem;">Learn, grow & track your progress</p>
    </div>
    @if (!User.IsInRole("ReadOnly") && (User.IsInRole("Admin") || User.IsInRole("Manager")))
    {
        <a asp-action="Create" class="btn btn-primary btn-sm"><i class="fas fa-plus me-1"></i>Add Course</a>
    }
</div>

<!-- Stats -->
<div class="row g-3 mb-4">
    <div class="col-md-3"><div class="card border-0 shadow-sm"><div class="card-body text-center"><i class="fas fa-book fa-2x text-primary mb-2"></i><h5 class="fw-bold">@Model.Count</h5><small class="text-muted">Available Courses</small></div></div></div>
    <div class="col-md-3"><div class="card border-0 shadow-sm"><div class="card-body text-center"><i class="fas fa-check-circle fa-2x text-success mb-2"></i><h5 class="fw-bold">@progress.Count(p => p.IsCompleted)</h5><small class="text-muted">Completed</small></div></div></div>
    <div class="col-md-3"><div class="card border-0 shadow-sm"><div class="card-body text-center"><i class="fas fa-spinner fa-2x text-warning mb-2"></i><h5 class="fw-bold">@progress.Count(p => !p.IsCompleted)</h5><small class="text-muted">In Progress</small></div></div></div>
    <div class="col-md-3"><div class="card border-0 shadow-sm"><div class="card-body text-center"><i class="fas fa-star fa-2x text-info mb-2"></i><h5 class="fw-bold">@(progress.Where(p => p.QuizScore.HasValue).Select(p => p.QuizScore!.Value).DefaultIfEmpty(0).Average().ToString("F0"))%</h5><small class="text-muted">Avg Score</small></div></div></div>
</div>

<!-- Category Filter -->
<div class="mb-4">
    <a href="@Url.Action("Index")" class="btn btn-sm @(ViewBag.Category == null ? "btn-primary" : "btn-outline-primary")">All</a>
    @foreach (var cat in Model.Select(c => c.Category).Where(c => c != null).Distinct())
    {
        <a href="@Url.Action("Index", new { category = cat })" class="btn btn-sm @(ViewBag.Category == cat ? "btn-primary" : "btn-outline-primary")">@cat</a>
    }
</div>

<!-- Courses Grid -->
<div class="row g-4">
    @foreach (var course in Model)
    {
        var userProg = progress.FirstOrDefault(p => p.CourseId == course.Id);
        var pct = userProg?.ProgressPercent ?? 0;
        var completed = userProg?.IsCompleted ?? false;
        <div class="col-md-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start mb-2">
                        <span class="badge bg-@(course.Difficulty == "Beginner" ? "success" : course.Difficulty == "Intermediate" ? "warning" : "danger")">@course.Difficulty</span>
                        @if (course.IsMandatory) { <span class="badge bg-danger"><i class="fas fa-star me-1"></i>Required</span> }
                        @if (completed) { <span class="badge bg-success"><i class="fas fa-check me-1"></i>Done</span> }
                    </div>
                    <h6 class="fw-bold">@course.Title</h6>
                    <p class="text-muted small mb-2">@(course.Description?.Length > 100 ? course.Description[..100] + "..." : course.Description)</p>
                    <div class="d-flex align-items-center gap-3 small text-muted mb-3">
                        @if (course.Category != null) { <span><i class="fas fa-tag me-1"></i>@course.Category</span> }
                        <span><i class="fas fa-clock me-1"></i>@course.DurationMinutes min</span>
                        @if (course.VideoUrl != null) { <span><i class="fas fa-video text-danger"></i></span> }
                    </div>
                    @if (pct > 0)
                    {
                        <div class="progress mb-3" style="height:6px;">
                            <div class="progress-bar bg-@(completed ? "success" : "primary")" style="width:@(pct)%"></div>
                        </div>
                    }
                    <a asp-action="View" asp-route-id="@course.Id" class="btn btn-sm @(completed ? "btn-outline-success" : pct > 0 ? "btn-primary" : "btn-outline-primary") w-100">
                        <i class="fas fa-@(completed ? "redo" : pct > 0 ? "play" : "book-open") me-1"></i>
                        @(completed ? "Review" : pct > 0 ? "Continue" : "Start Course")
                    </a>
                </div>
            </div>
        </div>
    }
    @if (!Model.Any())
    {
        <div class="col-12 text-center py-5 text-muted">
            <i class="fas fa-graduation-cap fa-3x mb-3 opacity-25"></i>
            <p>No training courses available yet.</p>
        </div>
    }
</div>
