@model List<Employeemanagementpractice.Models.TeamLeader>
@{
    ViewData["Title"] = "Team Leaders";
    var canCreate = User.IsInRole("Admin") || User.IsInRole("Manager");
    var canDelete = User.IsInRole("Admin") || User.IsInRole("Manager");
}

<div class="fade-in">
    <div class="page-header">
        <h2 style="font-size:1.1rem;"><i class="fas fa-user-tie me-2"></i>Team Leaders</h2>
        @if (canCreate)
        {
            <a href="@Url.Action("Create")" class="btn btn-primary btn-sm"><i class="fas fa-plus me-1"></i>Add Team Leader</a>
        }
    </div>

    <!-- Filter Bar -->
    <div class="filter-bar">
        <form method="get" class="row g-2 align-items-end no-loading">
            <div class="col-md-6">
                <div class="input-group input-group-sm">
                    <span class="input-group-text bg-white"><i class="fas fa-search text-muted" style="font-size:0.7rem;"></i></span>
                    <input type="text" name="search" class="form-control" placeholder="Search name, employee no, department..." value="@ViewBag.Search" />
                </div>
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn btn-primary btn-sm w-100"><i class="fas fa-filter me-1"></i>Filter</button>
            </div>
            @if (!string.IsNullOrWhiteSpace(ViewBag.Search as string))
            {
                <div class="col-md-2">
                    <a href="@Url.Action("Index")" class="btn btn-outline-secondary btn-sm w-100"><i class="fas fa-times me-1"></i>Clear</a>
                </div>
            }
        </form>
    </div>

    <!-- Table -->
    <div class="table-container">
        <table class="table table-hover" id="teamLeadersTable">
            <thead>
                <tr>
                    <th>Employee No</th>
                    <th>Name</th>
                    <th>Email</th>
                    <th>Department</th>
                    <th>Students</th>
                    <th>Capacity</th>
                    <th>Status</th>
                    <th style="width:120px;">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var tl in Model)
                {
                    var pct = tl.MaxStudents > 0 ? (int)((double)tl.Students.Count(x => x.IsActive) / tl.MaxStudents * 100) : 0;
                    var barColor = pct >= 90 ? "bg-danger" : pct >= 70 ? "bg-warning" : "bg-success";
                    <tr>
                        <td><span class="badge bg-light text-dark fw-bold">@tl.EmployeeNumber</span></td>
                        <td>
                            <a href="@Url.Action("Details", new { id = tl.Id })" class="text-decoration-none fw-bold">
                                <i class="fas fa-user-tie me-1 text-primary"></i>@tl.User.FullName
                            </a>
                        </td>
                        <td><small class="text-muted">@tl.User.Email</small></td>
                        <td>@(tl.Department ?? "—")</td>
                        <td>
                            <a href="@Url.Action("Students", new { id = tl.Id })" class="text-decoration-none">
                                <span class="badge bg-primary">@tl.Students.Count(x => x.IsActive)</span> / @tl.MaxStudents
                            </a>
                        </td>
                        <td style="min-width:120px;">
                            <div class="progress progress-thin"><div class="progress-bar @barColor" style="width:@pct%"></div></div>
                            <small class="text-muted">@pct%</small>
                        </td>
                        <td><span class="badge @(tl.IsActive ? "bg-success" : "bg-secondary") badge-status">@(tl.IsActive ? "Active" : "Inactive")</span></td>
                        <td>
                            <div class="btn-group btn-group-sm">
                                <a href="@Url.Action("Details", new { id = tl.Id })" class="btn btn-outline-primary" data-bs-toggle="tooltip" title="View Details">
                                    <i class="fas fa-eye"></i>
                                </a>
                                @if (canCreate)
                                {
                                    <a href="@Url.Action("Edit", new { id = tl.Id })" class="btn btn-outline-warning" data-bs-toggle="tooltip" title="Edit">
                                        <i class="fas fa-edit"></i>
                                    </a>
                                }
                                @if (canDelete)
                                {
                                    <button class="btn btn-outline-danger" data-bs-toggle="modal" data-bs-target="#deleteModal-@tl.Id" title="Deactivate">
                                        <i class="fas fa-ban"></i>
                                    </button>
                                }
                            </div>

                            <!-- Delete Modal -->
                            <div class="modal fade" id="deleteModal-@tl.Id" tabindex="-1">
                                <div class="modal-dialog modal-dialog-centered">
                                    <div class="modal-content">
                                        <div class="modal-header bg-danger text-white">
                                            <h5 class="modal-title"><i class="fas fa-exclamation-triangle me-2"></i>Confirm Deactivation</h5>
                                            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                                        </div>
                                        <div class="modal-body text-center">
                                            <i class="fas fa-user-tie fa-3x text-danger mb-3"></i>
                                            <p>Are you sure you want to deactivate <strong>@tl.User.FullName</strong>?</p>
                                            <p class="text-muted small">This will also lock their account. Students under this leader will need reassignment.</p>
                                        </div>
                                        <div class="modal-footer">
                                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                                            <form asp-action="Delete" method="post">
                                                <input type="hidden" name="id" value="@tl.Id" />
                                                <button type="submit" class="btn btn-danger"><i class="fas fa-ban me-1"></i>Deactivate</button>
                                            </form>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr><td colspan="8" class="text-center text-muted py-5">
                        <i class="fas fa-user-tie fa-3x mb-3 d-block opacity-25"></i>
                        No team leaders found. <a href="@Url.Action("Create")">Add one now</a>.
                    </td></tr>
                }
            </tbody>
        </table>

        <!-- Pagination -->
        @if ((int)ViewBag.TotalPages > 1)
        {
            <div class="pagination-wrapper">
                <span class="text-muted small">
                    Showing page @ViewBag.Page of @ViewBag.TotalPages (@ViewBag.TotalCount total)
                </span>
                <nav>
                    <ul class="pagination pagination-sm mb-0">
                        @for (int i = 1; i <= (int)ViewBag.TotalPages; i++)
                        {
                            <li class="page-item @(i == (int)ViewBag.Page ? "active" : "")">
                                <a class="page-link" href="@Url.Action("Index", new { page = i, search = ViewBag.Search })">@i</a>
                            </li>
                        }
                    </ul>
                </nav>
            </div>
        }
    </div>

    <!-- Export -->
    <div class="mt-3">
        <button class="btn btn-danger btn-sm" onclick="exportTableToPDF('teamLeadersTable','Team Leaders Report')">
            <i class="fas fa-file-pdf me-1"></i>Export PDF
        </button>
    </div>
</div>
