@model Employeemanagementpractice.Models.ViewModels.ChangePasswordViewModel
@{
    ViewData["Title"] = "Change Password";
    Layout = null;
    var mustChange = (bool)(ViewBag.MustChange ?? false);
    var deadline = ViewBag.Deadline as DateTime?;
    var userName = ViewBag.UserName as string ?? "User";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Change Password - BA Academy</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
    <style>
        body { background: linear-gradient(135deg, #1e293b 0%, #334155 100%); min-height: 100vh; display: flex; align-items: center; justify-content: center; }
        .card { border: none; border-radius: 16px; box-shadow: 0 20px 60px rgba(0,0,0,0.3); }
        .password-strength { height: 4px; border-radius: 2px; transition: all 0.3s; }
    </style>
</head>
<body>
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-5">
                <div class="text-center mb-4">
                    <img src="/images/ba-academy-logo.svg" alt="BA Academy" style="height:48px;" class="mb-2" />
                    <h5 class="text-white fw-bold">BA Academy</h5>
                </div>
                <div class="card">
                    <div class="card-body p-4">
                        <div class="text-center mb-3">
                            <div class="bg-warning bg-opacity-10 rounded-circle d-inline-flex align-items-center justify-content-center" style="width:60px;height:60px;">
                                <i class="fas fa-key fa-2x text-warning"></i>
                            </div>
                            <h5 class="fw-bold mt-2 mb-1">Change Your Password</h5>
                            <p class="text-muted small mb-0">Welcome, <strong>@userName</strong></p>
                        </div>

                        @if (mustChange)
                        {
                            <div class="alert alert-warning py-2 small">
                                <i class="fas fa-exclamation-triangle me-1"></i>
                                <strong>Password change required.</strong> You are using a default password and must change it to continue.
                                @if (deadline.HasValue)
                                {
                                    var remaining = deadline.Value - DateTime.UtcNow;
                                    if (remaining.TotalHours > 0)
                                    {
                                        <text><br /><i class="fas fa-clock me-1 mt-1"></i>You have <strong>@((int)remaining.TotalHours) hours</strong> remaining before your account is locked.</text>
                                    }
                                    else
                                    {
                                        <br /><span class="text-danger"><i class="fas fa-lock me-1"></i>Deadline has passed! Change now or your account will be locked.</span>
                                    }
                                }
                            </div>
                        }

                        <div asp-validation-summary="All" class="text-danger small"></div>

                        <form asp-action="ChangePassword" method="post">
                            @Html.AntiForgeryToken()

                            <div class="mb-3">
                                <label class="form-label small fw-bold">Current Password</label>
                                <div class="input-group">
                                    <span class="input-group-text"><i class="fas fa-lock text-muted"></i></span>
                                    <input asp-for="CurrentPassword" class="form-control" placeholder="Enter current password" />
                                    <button type="button" class="btn btn-outline-secondary toggle-pw" data-target="CurrentPassword"><i class="fas fa-eye"></i></button>
                                </div>
                                <span asp-validation-for="CurrentPassword" class="text-danger small"></span>
                                @if (mustChange)
                                {
                                    <small class="text-muted">Default password: <code>Student@1234</code></small>
                                }
                            </div>

                            <div class="mb-3">
                                <label class="form-label small fw-bold">New Password</label>
                                <div class="input-group">
                                    <span class="input-group-text"><i class="fas fa-key text-muted"></i></span>
                                    <input asp-for="NewPassword" class="form-control" placeholder="Enter new password" id="newPw" />
                                    <button type="button" class="btn btn-outline-secondary toggle-pw" data-target="NewPassword"><i class="fas fa-eye"></i></button>
                                </div>
                                <span asp-validation-for="NewPassword" class="text-danger small"></span>
                                <div class="password-strength bg-secondary mt-1" id="pwStrength"></div>
                                <small class="text-muted" id="pwHint">Min 8 chars, uppercase, lowercase, digit, special char</small>
                            </div>

                            <div class="mb-4">
                                <label class="form-label small fw-bold">Confirm New Password</label>
                                <div class="input-group">
                                    <span class="input-group-text"><i class="fas fa-check-circle text-muted"></i></span>
                                    <input asp-for="ConfirmPassword" class="form-control" placeholder="Confirm new password" />
                                    <button type="button" class="btn btn-outline-secondary toggle-pw" data-target="ConfirmPassword"><i class="fas fa-eye"></i></button>
                                </div>
                                <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                            </div>

                            <button type="submit" class="btn btn-primary w-100 fw-bold"><i class="fas fa-save me-2"></i>Change Password</button>

                            @if (!mustChange)
                            {
                                <a href="/" class="btn btn-outline-secondary w-100 mt-2"><i class="fas fa-arrow-left me-1"></i>Back to Dashboard</a>
                            }
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script>
        // Toggle password visibility
        document.querySelectorAll('.toggle-pw').forEach(btn => {
            btn.addEventListener('click', () => {
                const input = document.getElementById(btn.dataset.target) || document.querySelector(`[name="${btn.dataset.target}"]`);
                if (!input) return;
                const isPassword = input.type === 'password';
                input.type = isPassword ? 'text' : 'password';
                btn.querySelector('i').className = isPassword ? 'fas fa-eye-slash' : 'fas fa-eye';
            });
        });

        // Password strength meter
        document.getElementById('newPw')?.addEventListener('input', function () {
            const pw = this.value;
            let score = 0;
            if (pw.length >= 8) score++;
            if (/[A-Z]/.test(pw)) score++;
            if (/[a-z]/.test(pw)) score++;
            if (/[0-9]/.test(pw)) score++;
            if (/[^A-Za-z0-9]/.test(pw)) score++;
            const bar = document.getElementById('pwStrength');
            const colors = ['bg-danger', 'bg-danger', 'bg-warning', 'bg-info', 'bg-success', 'bg-success'];
            const widths = [0, 20, 40, 60, 80, 100];
            bar.className = `password-strength ${colors[score]}`;
            bar.style.width = widths[score] + '%';
        });
    </script>
</body>
</html>
