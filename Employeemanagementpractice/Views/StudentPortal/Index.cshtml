@using Employeemanagementpractice.Services
@{
    ViewData["Title"] = "Student Portal";
    var student = ViewBag.Student as Employeemanagementpractice.Models.Student;
    var todayRecord = ViewBag.TodayRecord as Employeemanagementpractice.Models.AttendanceRecord;
    var diary = ViewBag.Diary as Employeemanagementpractice.Models.DailyDiary;
    var history = ViewBag.History as List<Employeemanagementpractice.Models.AttendanceRecord> ?? new();
    var hasClockedIn = todayRecord?.ClockInTime != null;
    var hasClockedOut = todayRecord?.ClockOutTime != null;
}

<div class="fade-in">
    <!-- Welcome Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h4 class="fw-bold mb-0"><i class="fas fa-user-graduate text-primary me-2"></i>Welcome, @student?.FullName</h4>
            <p class="text-muted mb-0 small">@SastClock.Now.ToString("dddd, dd MMMM yyyy") &bull; Team Leader: <strong>@student?.TeamLeader?.User?.FullName</strong></p>
        </div>
        <a href="@Url.Action("History")" class="btn btn-outline-primary btn-sm"><i class="fas fa-history me-1"></i>View History</a>
    </div>

    <!-- Stats Row -->
    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="card border-0 shadow-sm text-center p-3">
                <i class="fas fa-clock fa-2x text-primary mb-2"></i>
                <h6 class="text-muted mb-1">Today</h6>
                <span class="fw-bold fs-5" id="todayStatus">
                    @if (hasClockedOut) { <span class="text-success">Complete</span> }
                    else if (hasClockedIn) { <span class="text-warning">Clocked In</span> }
                    else { <span class="text-secondary">Not Started</span> }
                </span>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm text-center p-3">
                <i class="fas fa-sign-in-alt fa-2x text-success mb-2"></i>
                <h6 class="text-muted mb-1">Clock In</h6>
                <span class="fw-bold fs-5" id="clockInDisplay">@(todayRecord?.ClockInTime?.ToString("HH:mm") ?? "--:--")</span>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm text-center p-3">
                <i class="fas fa-sign-out-alt fa-2x text-danger mb-2"></i>
                <h6 class="text-muted mb-1">Clock Out</h6>
                <span class="fw-bold fs-5" id="clockOutDisplay">@(todayRecord?.ClockOutTime?.ToString("HH:mm") ?? "--:--")</span>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm text-center p-3">
                <i class="fas fa-hourglass-half fa-2x text-info mb-2"></i>
                <h6 class="text-muted mb-1">Hours Worked</h6>
                <span class="fw-bold fs-5" id="hoursDisplay">@(todayRecord?.HoursWorked?.ToString("F1") ?? "0.0") hrs</span>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <!-- Left: Clock In/Out Panel -->
        <div class="col-lg-7">
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
                    <h6 class="mb-0"><i class="fas fa-fingerprint me-2"></i>Attendance Clock</h6>
                    <span class="badge bg-light text-dark" id="currentTime"></span>
                </div>
                <div class="card-body">
                    <!-- Location Status -->
                    <div class="alert alert-info py-2 small mb-3" id="locationStatus">
                        <i class="fas fa-map-marker-alt me-1"></i>
                        <span id="locationText">Detecting location...</span>
                        <button class="btn btn-sm btn-outline-primary ms-2 d-none" id="btnRetryLocation" onclick="getLocation()"><i class="fas fa-redo me-1"></i>Retry</button>
                    </div>
                    <!-- Location Required Warning -->
                    <div class="alert alert-warning py-2 small mb-3 d-none" id="locationRequiredWarning">
                        <i class="fas fa-exclamation-triangle me-1"></i>
                        <strong>Location is required!</strong> Please enable location services on your device to clock in/out.
                        <br><small class="text-muted mt-1 d-block"><i class="fas fa-info-circle me-1"></i>Go to your device Settings &gt; Privacy &gt; Location Services and enable for your browser.</small>
                    </div>

                    <!-- Device Info -->
                    <div class="d-flex justify-content-between align-items-center mb-3 small text-muted">
                        <span><i class="fas fa-mobile-alt me-1"></i>Device: <strong id="deviceName">Detecting...</strong></span>
                        <span><i class="fas fa-wifi me-1"></i><span id="connectionStatus">Online</span></span>
                    </div>

                    <!-- Selfie Camera -->
                    <div class="text-center mb-3">
                        <div class="position-relative d-inline-block" style="max-width:320px;">
                            <video id="cameraPreview" autoplay playsinline muted class="rounded border w-100" style="display:none;max-height:240px;"></video>
                            <canvas id="selfieCanvas" style="display:none;"></canvas>
                            <img id="capturedSelfie" class="rounded border w-100" style="display:none;max-height:240px;" />
                            <div id="cameraPlaceholder" class="border rounded p-4 text-muted">
                                <i class="fas fa-camera fa-3x mb-2 d-block opacity-50"></i>
                                <small>Camera will activate for verification</small>
                            </div>
                        </div>
                    </div>

                    <!-- Clock Buttons -->
                    <div class="d-flex gap-3 justify-content-center">
                        @if (!hasClockedIn)
                        {
                            <button class="btn btn-success btn-lg px-5" id="btnClockIn" onclick="startClockProcess('in')">
                                <i class="fas fa-sign-in-alt me-2"></i>Clock In
                            </button>
                        }
                        else if (!hasClockedOut)
                        {
                            <button class="btn btn-danger btn-lg px-5" id="btnClockOut" onclick="startClockProcess('out')">
                                <i class="fas fa-sign-out-alt me-2"></i>Clock Out
                            </button>
                        }
                        else
                        {
                            <div class="alert alert-success text-center w-100 mb-0">
                                <i class="fas fa-check-circle fa-2x mb-2 d-block"></i>
                                <strong>Attendance recorded for today!</strong><br/>
                                <small>In: @todayRecord?.ClockInTime?.ToString("HH:mm") &bull; Out: @todayRecord?.ClockOutTime?.ToString("HH:mm") &bull; @todayRecord?.HoursWorked?.ToString("F1") hours</small>
                            </div>
                        }
                    </div>

                    <!-- Map -->
                    <div class="mt-3" id="mapContainer" style="display:none;">
                        <small class="text-muted"><i class="fas fa-map me-1"></i>Your location: <span id="addressDisplay">-</span></small>
                        <div class="text-muted small mt-1">Lat: <span id="latDisplay">-</span> &bull; Lng: <span id="lngDisplay">-</span></div>
                    </div>
                </div>
            </div>

            <!-- Recent History -->
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white fw-bold"><i class="fas fa-calendar-alt me-2"></i>Recent Attendance (Last 7 days)</div>
                <div class="card-body p-0">
                    <table class="table table-hover mb-0 small">
                        <thead class="table-light"><tr><th>Date</th><th>Status</th><th>Clock In</th><th>Clock Out</th><th>Hours</th><th>Device</th></tr></thead>
                        <tbody>
                            @foreach (var r in history.Take(7))
                            {
                                var badge = r.Status switch { "Present" => "bg-success", "Late" => "bg-warning text-dark", "Absent" => "bg-danger", _ => "bg-secondary" };
                                <tr>
                                    <td data-label="Date">@r.Date.ToString("ddd dd MMM")</td>
                                    <td data-label="Status"><span class="badge @badge">@r.Status</span> @if(r.IsMarkedByProxy){<small class="text-muted">(proxy)</small>}</td>
                                    <td data-label="Clock In">@(r.ClockInTime?.ToString("HH:mm") ?? r.CheckInTime?.ToString(@"hh\:mm") ?? "-")</td>
                                    <td data-label="Clock Out">@(r.ClockOutTime?.ToString("HH:mm") ?? r.CheckOutTime?.ToString(@"hh\:mm") ?? "-")</td>
                                    <td data-label="Hours">@(r.HoursWorked?.ToString("F1") ?? "-")</td>
                                    <td data-label="Device"><small class="text-muted">@(r.ClockInDeviceName ?? "-")</small></td>
                                </tr>
                            }
                            @if (!history.Any())
                            {
                                <tr><td colspan="6" class="text-center text-muted py-3">No attendance records yet.</td></tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- Right: Daily Diary -->
        <div class="col-lg-5">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-warning text-dark d-flex justify-content-between align-items-center">
                    <h6 class="mb-0"><i class="fas fa-book me-2"></i>Daily Diary</h6>
                    <small>@SastClock.Now.ToString("dd MMM yyyy")</small>
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <label class="form-label fw-bold small"><i class="fas fa-tasks me-1 text-primary"></i>Activities Today</label>
                        <textarea id="diaryActivities" class="form-control" rows="3" placeholder="What did you work on today?">@diary?.Activities</textarea>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold small"><i class="fas fa-trophy me-1 text-success"></i>Achievements</label>
                        <textarea id="diaryAchievements" class="form-control" rows="2" placeholder="What did you accomplish?">@diary?.Achievements</textarea>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold small"><i class="fas fa-exclamation-triangle me-1 text-warning"></i>Challenges</label>
                        <textarea id="diaryChallenges" class="form-control" rows="2" placeholder="Any challenges faced?">@diary?.Challenges</textarea>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold small"><i class="fas fa-forward me-1 text-info"></i>Plan for Tomorrow</label>
                        <textarea id="diaryTomorrow" class="form-control" rows="2" placeholder="What do you plan to do tomorrow?">@diary?.PlannedForTomorrow</textarea>
                    </div>
                    @if (!string.IsNullOrEmpty(diary?.SupervisorComment))
                    {
                        <div class="alert alert-info py-2 small">
                            <i class="fas fa-comment me-1"></i><strong>Supervisor:</strong> @diary.SupervisorComment
                        </div>
                    }
                    <button class="btn btn-warning w-100" onclick="saveDiary()">
                        <i class="fas fa-save me-1"></i>Save Diary Entry
                    </button>
                    @if (diary?.UpdatedAt != null)
                    {
                        <small class="text-muted d-block text-center mt-2">Last saved: @diary.UpdatedAt?.ToString("HH:mm")</small>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
// ── Live Clock (SAST 24-hour) ──
function updateClock() {
    var options = { timeZone: 'Africa/Johannesburg', hour: '2-digit', minute: '2-digit', second: '2-digit', hour12: false };
    document.getElementById('currentTime').textContent = new Date().toLocaleTimeString('en-ZA', options) + ' SAST';
}
setInterval(updateClock, 1000);
updateClock();

// ── Device Detection ──
var deviceName = navigator.userAgent.match(/\(([^)]+)\)/)?.[1] || navigator.platform || 'Unknown Device';
if (deviceName.includes('iPhone')) deviceName = 'iPhone';
else if (deviceName.includes('iPad')) deviceName = 'iPad';
else if (deviceName.includes('Android')) {
    var m = navigator.userAgent.match(/Android[^;]*;\s*([^)]+)/);
    deviceName = m ? m[1].trim() : 'Android Device';
} else if (deviceName.includes('Win')) deviceName = 'Windows PC';
else if (deviceName.includes('Mac')) deviceName = 'MacOS';
else if (deviceName.includes('Linux')) deviceName = 'Linux PC';
document.getElementById('deviceName').textContent = deviceName;

// ═══════════════════════════════════════════
// GEOLOCATION (Auto-detect + Required + Permission Trigger)
// ═══════════════════════════════════════════
var currentLat = null, currentLng = null, currentAddress = null;
var locationReady = false;
var watchId = null;

function getLocation() {
    if (!navigator.geolocation) {
        showLocationError('Geolocation not supported by this browser. Please use Chrome, Safari, or Edge.');
        return;
    }

    // First check permission state via Permissions API
    if (navigator.permissions && navigator.permissions.query) {
        navigator.permissions.query({ name: 'geolocation' }).then(function(result) {
            if (result.state === 'denied') {
                showLocationDenied();
                return;
            }
            // 'granted' or 'prompt' → proceed
            requestGeolocation();
            // Listen for permission changes
            result.onchange = function() {
                if (this.state === 'granted') {
                    requestGeolocation();
                } else if (this.state === 'denied') {
                    showLocationDenied();
                }
            };
        }).catch(function() {
            // Permissions API not supported, just try
            requestGeolocation();
        });
    } else {
        requestGeolocation();
    }
}

function showLocationDenied() {
    locationReady = false;
    document.getElementById('locationText').innerHTML = '<i class="fas fa-times-circle me-1"></i>Location permission denied';
    document.getElementById('locationStatus').className = 'alert alert-danger py-2 small mb-3';
    document.getElementById('btnRetryLocation').classList.remove('d-none');
    document.getElementById('locationRequiredWarning').classList.remove('d-none');
    // Show instructions to enable location
    document.getElementById('locationRequiredWarning').innerHTML =
        '<i class="fas fa-exclamation-triangle me-1"></i><strong>Location is required!</strong> Please enable location access for this site.' +
        '<br><small class="text-muted mt-1 d-block">' +
        '<i class="fas fa-mobile-alt me-1"></i><strong>Phone:</strong> Settings → Privacy → Location Services → Enable for your browser<br>' +
        '<i class="fas fa-globe me-1"></i><strong>Chrome:</strong> Click the lock/info icon &#x1F512; in the address bar → Location → Allow<br>' +
        '<i class="fas fa-laptop me-1"></i><strong>PC:</strong> Click the lock icon in the address bar → Site settings → Location → Allow' +
        '</small>' +
        '<button class="btn btn-sm btn-primary mt-2" onclick="openLocationSettings()"><i class="fas fa-cog me-1"></i>Open Settings Guide</button>';
    disableClockButtons();
}

function showLocationError(msg) {
    document.getElementById('locationText').innerHTML = '<i class="fas fa-times-circle me-1"></i>' + msg;
    document.getElementById('locationStatus').className = 'alert alert-danger py-2 small mb-3';
    document.getElementById('locationRequiredWarning').classList.remove('d-none');
    disableClockButtons();
}

function openLocationSettings() {
    // Try to trigger browser's location permission prompt by re-requesting
    if (navigator.geolocation) {
        navigator.geolocation.getCurrentPosition(
            function(pos) { getLocation(); },
            function(err) {
                // If still denied, show instructions based on device
                var isAndroid = /Android/i.test(navigator.userAgent);
                var isIOS = /iPhone|iPad|iPod/i.test(navigator.userAgent);
                var msg = '';
                if (isAndroid) msg = 'On Android: Open Chrome → Menu (⋮) → Settings → Site Settings → Location → Allow for this site. Also check: Phone Settings → Location → Turn ON';
                else if (isIOS) msg = 'On iPhone/iPad: Go to Settings → Safari → Location → Allow. Also: Settings → Privacy → Location Services → ON → Safari → While Using';
                else msg = 'On your browser: Click the lock/info icon in the address bar → Site Settings → Location → Allow. Then refresh the page.';
                alert(msg);
            },
            { enableHighAccuracy: true, timeout: 5000 }
        );
    }
}

function requestGeolocation() {
    document.getElementById('locationText').innerHTML = '<i class="fas fa-spinner fa-spin me-1"></i>Detecting your location...';
    document.getElementById('locationStatus').className = 'alert alert-info py-2 small mb-3';
    document.getElementById('btnRetryLocation').classList.add('d-none');
    document.getElementById('locationRequiredWarning').classList.add('d-none');

    if (watchId) navigator.geolocation.clearWatch(watchId);
    watchId = navigator.geolocation.watchPosition(
        function(pos) {
            currentLat = pos.coords.latitude;
            currentLng = pos.coords.longitude;
            locationReady = true;
            document.getElementById('latDisplay').textContent = currentLat.toFixed(6);
            document.getElementById('lngDisplay').textContent = currentLng.toFixed(6);
            document.getElementById('mapContainer').style.display = 'block';
            document.getElementById('locationStatus').className = 'alert alert-success py-2 small mb-3';
            document.getElementById('locationText').innerHTML = '<i class="fas fa-check-circle me-1"></i>Location detected!';
            document.getElementById('locationRequiredWarning').classList.add('d-none');
            enableClockButtons();
            // Reverse geocode
            fetch('https://nominatim.openstreetmap.org/reverse?format=json&lat=' + currentLat + '&lon=' + currentLng + '&zoom=18&addressdetails=1')
                .then(function(r) { return r.json(); })
                .then(function(d) {
                    currentAddress = d.display_name || (currentLat.toFixed(4) + ', ' + currentLng.toFixed(4));
                    document.getElementById('addressDisplay').textContent = currentAddress;
                    document.getElementById('locationText').innerHTML = '<i class="fas fa-check-circle me-1"></i>' + currentAddress.substring(0, 80) + (currentAddress.length > 80 ? '...' : '');
                })
                .catch(function() {
                    currentAddress = currentLat.toFixed(6) + ', ' + currentLng.toFixed(6);
                    document.getElementById('addressDisplay').textContent = currentAddress;
                });
        },
        function(err) {
            locationReady = false;
            if (err.code === 1) { showLocationDenied(); return; }
            var msg = err.code === 2 ? 'Location unavailable - check GPS/WiFi' : 'Location request timed out...';
            document.getElementById('locationText').innerHTML = '<i class="fas fa-times-circle me-1"></i>' + msg;
            document.getElementById('locationStatus').className = 'alert alert-danger py-2 small mb-3';
            document.getElementById('btnRetryLocation').classList.remove('d-none');
            document.getElementById('locationRequiredWarning').classList.remove('d-none');
            disableClockButtons();
            if (err.code === 3) setTimeout(getLocation, 3000);
        },
        { enableHighAccuracy: true, timeout: 15000, maximumAge: 30000 }
    );
}

function disableClockButtons() {
    document.querySelectorAll('#btnClockIn, #btnClockOut').forEach(function(b) { b.disabled = true; b.title = 'Location required'; });
}
function enableClockButtons() {
    document.querySelectorAll('#btnClockIn, #btnClockOut').forEach(function(b) { b.disabled = false; b.title = ''; });
}
getLocation();

// ═══════════════════════════════════════════
// OFFLINE STORAGE (IndexedDB for pending clocks)
// ═══════════════════════════════════════════
var dbName = 'BAAcademyOffline';
var storeName = 'pendingClocks';

function openOfflineDB() {
    return new Promise(function(resolve, reject) {
        var request = indexedDB.open(dbName, 1);
        request.onupgradeneeded = function(e) {
            var db = e.target.result;
            if (!db.objectStoreNames.contains(storeName)) {
                db.createObjectStore(storeName, { keyPath: 'id', autoIncrement: true });
            }
            if (!db.objectStoreNames.contains('pendingDiary')) {
                db.createObjectStore('pendingDiary', { keyPath: 'id', autoIncrement: true });
            }
        };
        request.onsuccess = function(e) { resolve(e.target.result); };
        request.onerror = function(e) { reject(e.target.error); };
    });
}

async function saveOfflineClock(direction, data) {
    try {
        var db = await openOfflineDB();
        var tx = db.transaction(storeName, 'readwrite');
        tx.objectStore(storeName).add({
            direction: direction,
            data: data,
            timestamp: new Date().toISOString(),
            synced: false
        });
        return true;
    } catch(e) { console.log('IndexedDB save failed:', e); return false; }
}

async function getPendingClocks() {
    try {
        var db = await openOfflineDB();
        return new Promise(function(resolve) {
            var tx = db.transaction(storeName, 'readonly');
            var req = tx.objectStore(storeName).getAll();
            req.onsuccess = function() { resolve(req.result.filter(function(r) { return !r.synced; })); };
            req.onerror = function() { resolve([]); };
        });
    } catch(e) { return []; }
}

async function markClockSynced(id) {
    try {
        var db = await openOfflineDB();
        var tx = db.transaction(storeName, 'readwrite');
        var store = tx.objectStore(storeName);
        var req = store.get(id);
        req.onsuccess = function() {
            var rec = req.result;
            if (rec) { rec.synced = true; store.put(rec); }
        };
    } catch(e) {}
}

async function syncPendingClocks() {
    if (!navigator.onLine) return;
    var pending = await getPendingClocks();
    if (!pending.length) return;

    var syncCount = 0;
    for (var i = 0; i < pending.length; i++) {
        var p = pending[i];
        var url = p.direction === 'in' ? '@Url.Action("ClockIn")' : '@Url.Action("ClockOut")';
        try {
            var res = await fetch(url, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(p.data)
            });
            var d = await res.json();
            if (d.success) { await markClockSynced(p.id); syncCount++; }
        } catch(e) { break; }
    }
    if (syncCount > 0) {
        if (typeof showToast === 'function') showToast('Synced ' + syncCount + ' offline clock record(s)', 'success');
        setTimeout(function() { location.reload(); }, 2000);
    }
}

// Listen for back-online event to sync
window.addEventListener('online', function() {
    document.getElementById('connectionStatus').innerHTML = '<span class="text-success"><i class="fas fa-wifi me-1"></i>Online</span>';
    syncPendingClocks();
});
window.addEventListener('offline', function() {
    document.getElementById('connectionStatus').innerHTML = '<span class="text-danger"><i class="fas fa-exclamation-triangle me-1"></i>Offline</span>';
});

// Listen for service worker sync message
if (navigator.serviceWorker) {
    navigator.serviceWorker.addEventListener('message', function(e) {
        if (e.data && e.data.type === 'SYNC_PENDING_CLOCKS') syncPendingClocks();
    });
}

// Auto-sync on page load
if (navigator.onLine) syncPendingClocks();

// ═══════════════════════════════════════════
// CAMERA / SELFIE
// ═══════════════════════════════════════════
var cameraStream = null;
var capturedBase64 = null;

async function startCamera() {
    try {
        cameraStream = await navigator.mediaDevices.getUserMedia({ video: { facingMode: 'user', width: 320, height: 240 } });
        var video = document.getElementById('cameraPreview');
        video.srcObject = cameraStream;
        video.style.display = 'block';
        document.getElementById('cameraPlaceholder').style.display = 'none';
        document.getElementById('capturedSelfie').style.display = 'none';
        return true;
    } catch(e) { console.log('Camera not available:', e); return false; }
}

function captureSelfie() {
    var video = document.getElementById('cameraPreview');
    var canvas = document.getElementById('selfieCanvas');
    canvas.width = video.videoWidth || 320;
    canvas.height = video.videoHeight || 240;
    canvas.getContext('2d').drawImage(video, 0, 0);
    capturedBase64 = canvas.toDataURL('image/jpeg', 0.7);
    document.getElementById('capturedSelfie').src = capturedBase64;
    document.getElementById('capturedSelfie').style.display = 'block';
    video.style.display = 'none';
    stopCamera();
}

function stopCamera() {
    if (cameraStream) { cameraStream.getTracks().forEach(function(t) { t.stop(); }); cameraStream = null; }
}

// ═══════════════════════════════════════════
// CLOCK PROCESS (Online + Offline)
// ═══════════════════════════════════════════
async function startClockProcess(direction) {
    var btn = direction === 'in' ? document.getElementById('btnClockIn') : document.getElementById('btnClockOut');
    if (btn) btn.disabled = true;

    // REQUIRE location
    if (!locationReady || !currentLat || !currentLng) {
        if (typeof showToast === 'function') showToast('Please enable location services. Your location is required to clock ' + direction + '.', 'error');
        else alert('Please enable location services. Your location is required to clock ' + direction + '.');
        document.getElementById('locationRequiredWarning').classList.remove('d-none');
        getLocation();
        if (btn) btn.disabled = false;
        return;
    }

    // Camera selfie
    var cameraAvailable = await startCamera();
    if (cameraAvailable) {
        await new Promise(function(r) { setTimeout(r, 2000); });
        captureSelfie();
    }

    var clockData = {
        latitude: currentLat,
        longitude: currentLng,
        address: currentAddress,
        deviceName: deviceName,
        selfieBase64: capturedBase64
    };

    // Try online first, fall back to offline storage
    if (navigator.onLine) {
        var url = direction === 'in' ? '@Url.Action("ClockIn")' : '@Url.Action("ClockOut")';
        try {
            var res = await fetch(url, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(clockData)
            });
            var data = await res.json();
            if (data.success) {
                if (typeof showToast === 'function') showToast('Clock ' + direction + ' successful: ' + data.time + ' SAST', 'success');
                else alert('Clock ' + direction + ' successful: ' + data.time + ' SAST');
                setTimeout(function() { location.reload(); }, 1500);
                return;
            } else {
                if (typeof showToast === 'function') showToast(data.message || 'Failed', 'error');
                else alert(data.message || 'Failed');
                if (btn) btn.disabled = false;
                return;
            }
        } catch(e) {
            // Network failed — save offline
            console.log('Network error, saving offline...');
        }
    }

    // OFFLINE: Save to IndexedDB for later sync
    var saved = await saveOfflineClock(direction, clockData);
    if (saved) {
        if (typeof showToast === 'function') showToast('You are offline. Clock ' + direction + ' saved locally and will sync when you are back online.', 'warning');
        else alert('You are offline. Clock ' + direction + ' saved locally and will sync when online.');
        // Register background sync if supported
        if ('serviceWorker' in navigator && 'SyncManager' in window) {
            var reg = await navigator.serviceWorker.ready;
            try { await reg.sync.register('sync-clock-data'); } catch(e) {}
        }
    } else {
        alert('Failed to save offline. Please try again.');
    }
    if (btn) btn.disabled = false;
}

// ═══════════════════════════════════════════
// DIARY (with offline save)
// ═══════════════════════════════════════════
async function saveDiary() {
    var diaryData = {
        activities: document.getElementById('diaryActivities').value,
        achievements: document.getElementById('diaryAchievements').value,
        challenges: document.getElementById('diaryChallenges').value,
        plannedForTomorrow: document.getElementById('diaryTomorrow').value
    };

    if (navigator.onLine) {
        try {
            var res = await fetch('@Url.Action("SaveDiary")', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(diaryData)
            });
            var data = await res.json();
            if (data.success) {
                if (typeof showToast === 'function') showToast('Diary saved successfully!', 'success');
                else alert('Diary saved!');
            }
            return;
        } catch(e) {}
    }

    // Offline: save to IndexedDB
    try {
        var db = await openOfflineDB();
        var tx = db.transaction('pendingDiary', 'readwrite');
        tx.objectStore('pendingDiary').add({ data: diaryData, timestamp: new Date().toISOString(), synced: false });
        if (typeof showToast === 'function') showToast('You are offline. Diary saved locally — will sync when online.', 'warning');
        else alert('Offline — diary saved locally.');
    } catch(e) { alert('Failed to save diary.'); }
}

// ── Pending Offline Indicator ──
(async function showPendingCount() {
    var p = await getPendingClocks();
    if (p.length > 0) {
        var indicator = document.createElement('div');
        indicator.className = 'alert alert-warning py-2 small mb-3';
        indicator.innerHTML = '<i class="fas fa-cloud-upload-alt me-1"></i><strong>' + p.length + ' pending offline clock record(s)</strong> — will sync automatically when online.' +
            (navigator.onLine ? ' <button class="btn btn-sm btn-warning ms-2" onclick="syncPendingClocks()"><i class="fas fa-sync me-1"></i>Sync Now</button>' : '');
        var wrapper = document.querySelector('.fade-in .row.g-4');
        if (wrapper) wrapper.parentNode.insertBefore(indicator, wrapper);
    }
})();
</script>
