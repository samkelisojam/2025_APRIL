@model List<Employeemanagementpractice.Models.TaskItem>
@{ ViewData["Title"] = "Tasks"; }

<div class="fade-in">
    <div class="page-header">
        <h2 style="font-size:1.1rem;"><i class="fas fa-tasks me-2"></i>Tasks</h2>
        @if (!User.IsInRole("ReadOnly"))
        {
            <a href="@Url.Action("Create")" class="btn btn-primary btn-sm"><i class="fas fa-plus me-1"></i>New Task</a>
        }
    </div>

    <!-- Filter -->
    <div class="filter-bar">
        <form method="get" class="row g-2 align-items-end no-loading">
            <div class="col-md-3">
                <select name="status" class="form-select form-select-sm">
                    <option value="">All Status</option>
                    @foreach (var s in Enum.GetValues<Employeemanagementpractice.Models.TaskStatus>())
                    {
                        if (ViewBag.Status == s.ToString()) { <option value="@s" selected="selected">@s</option> }
                        else { <option value="@s">@s</option> }
                    }
                </select>
            </div>
            <div class="col-md-3">
                <select name="priority" class="form-select form-select-sm">
                    <option value="">All Priority</option>
                    @foreach (var p in Enum.GetValues<Employeemanagementpractice.Models.TaskPriority>())
                    {
                        if (ViewBag.Priority == p.ToString()) { <option value="@p" selected="selected">@p</option> }
                        else { <option value="@p">@p</option> }
                    }
                </select>
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn btn-primary btn-sm w-100"><i class="fas fa-filter me-1"></i>Filter</button>
            </div>
            <div class="col-md-2">
                <a href="@Url.Action("Index")" class="btn btn-outline-secondary btn-sm w-100"><i class="fas fa-times me-1"></i>Clear</a>
            </div>
        </form>
    </div>

    <div class="table-container">
        <table class="table table-hover">
            <thead><tr><th>Title</th><th>Assigned To</th><th>Priority</th><th>Status</th><th>Due Date</th><th>Comments</th><th>Actions</th></tr></thead>
            <tbody>
                @foreach (var t in Model)
                {
                    var priorityClass = t.Priority switch { Employeemanagementpractice.Models.TaskPriority.Low => "priority-low", Employeemanagementpractice.Models.TaskPriority.Medium => "priority-medium", Employeemanagementpractice.Models.TaskPriority.High => "priority-high", _ => "priority-urgent" };
                    var statusBadge = t.Status switch { Employeemanagementpractice.Models.TaskStatus.New => "bg-secondary", Employeemanagementpractice.Models.TaskStatus.InProgress => "bg-primary", Employeemanagementpractice.Models.TaskStatus.Completed => "bg-success", _ => "bg-warning" };
                    <tr>
                        <td><a href="@Url.Action("Details",new{id=t.Id})" class="fw-bold text-decoration-none">@t.Title</a></td>
                        <td><i class="fas fa-user me-1 text-muted"></i>@t.AssignedTo?.FullName</td>
                        <td><span class="@priorityClass fw-bold"><i class="fas fa-flag me-1"></i>@t.Priority</span></td>
                        <td><span class="badge @statusBadge badge-status">@t.Status</span></td>
                        <td>@(t.DueDate?.ToString("dd MMM yyyy") ?? "—")</td>
                        <td><span class="badge bg-light text-dark">@t.Comments.Count</span></td>
                        <td>
                            <a href="@Url.Action("Details",new{id=t.Id})" class="btn btn-sm btn-outline-primary"><i class="fas fa-eye"></i></a>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr><td colspan="7" class="text-center text-muted py-5"><i class="fas fa-tasks fa-3x mb-3 d-block opacity-25"></i>No tasks found.</td></tr>
                }
            </tbody>
        </table>

        @if ((int)ViewBag.TotalPages > 1)
        {
            <div class="pagination-wrapper">
                <span class="text-muted small">Page @ViewBag.Page of @ViewBag.TotalPages</span>
                <nav><ul class="pagination pagination-sm mb-0">
                    @for (int i = 1; i <= (int)ViewBag.TotalPages; i++)
                    {
                        <li class="page-item @(i == (int)ViewBag.Page ? "active" : "")"><a class="page-link" href="@Url.Action("Index",new{page=i,status=ViewBag.Status,priority=ViewBag.Priority})">@i</a></li>
                    }
                </ul></nav>
            </div>
        }
    </div>
</div>
