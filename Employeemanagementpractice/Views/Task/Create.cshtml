@model Employeemanagementpractice.Models.ViewModels.TaskViewModel
@using Microsoft.AspNetCore.Mvc.Rendering
@{ ViewData["Title"] = "Create Task"; }

<div class="fade-in">
    <div class="page-header">
        <div>
            <a href="@Url.Action("Index")" class="text-decoration-none text-muted small"><i class="fas fa-arrow-left me-1"></i>Back to Tasks</a>
            <h2 class="mt-1" style="font-size:1.1rem;"><i class="fas fa-plus me-2"></i>Create Task</h2>
        </div>
    </div>

    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="stat-card">
                <form asp-action="Create" method="post" enctype="multipart/form-data">
                    <div asp-validation-summary="All" class="alert alert-danger" style="display:none;"></div>

                    <div class="row g-3">
                        <div class="col-md-12">
                            <label asp-for="Title" class="form-label fw-bold">Title <span class="text-danger">*</span></label>
                            <input asp-for="Title" class="form-control" placeholder="Task title..." />
                            <span asp-validation-for="Title" class="text-danger small"></span>
                        </div>
                        <div class="col-md-12">
                            <label asp-for="Description" class="form-label fw-bold">Description</label>
                            <textarea asp-for="Description" class="form-control" rows="4" placeholder="Detailed description..."></textarea>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="AssignedToUserId" class="form-label fw-bold">Assign To <span class="text-danger">*</span></label>
                            <select asp-for="AssignedToUserId" class="form-select">
                                <option value="">-- Select User --</option>
                                @foreach (var u in ViewBag.Users as List<SelectListItem>)
                                {
                                    <option value="@u.Value">@u.Text</option>
                                }
                            </select>
                            <span asp-validation-for="AssignedToUserId" class="text-danger small"></span>
                        </div>
                        <div class="col-md-3">
                            <label asp-for="Priority" class="form-label fw-bold">Priority</label>
                            <select asp-for="Priority" asp-items="Html.GetEnumSelectList<Employeemanagementpractice.Models.TaskPriority>()" class="form-select"></select>
                        </div>
                        <div class="col-md-3">
                            <label asp-for="DueDate" class="form-label fw-bold">Due Date</label>
                            <input asp-for="DueDate" type="date" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Attachment" class="form-label fw-bold">Attachment <small class="text-muted">(Optional)</small></label>
                            <input type="file" asp-for="Attachment" class="form-control" />
                        </div>
                    </div>

                    <div class="d-flex gap-2 mt-4">
                        <button type="submit" class="btn btn-primary"><i class="fas fa-paper-plane me-2"></i>Create Task</button>
                        <a href="@Url.Action("Index")" class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
