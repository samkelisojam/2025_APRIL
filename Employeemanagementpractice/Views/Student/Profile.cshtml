@model Employeemanagementpractice.Models.Student
@{ ViewData["Title"] = Model.FullName + " - Profile"; }

<div class="fade-in">
    <div class="page-header">
        <div>
            <a href="@Url.Action("Index")" class="text-decoration-none text-muted small"><i class="fas fa-arrow-left me-1"></i>Back to Students</a>
            <h2 class="mt-1"><i class="fas fa-user-graduate me-2"></i>@Model.FullName</h2>
        </div>
        <div>
            <a href="@Url.Action("Edit", new { id = Model.Id })" class="btn btn-warning"><i class="fas fa-edit me-1"></i>Edit</a>
        </div>
    </div>

    <div class="row g-4">
        <!-- Left: Profile Card -->
        <div class="col-lg-4">
            <div class="profile-card mb-4">
                <div class="profile-header">
                    <img src="@Url.Action("GetProfileImage", new { id = Model.Id })" alt="Profile" class="profile-avatar" />
                    <h4 class="mt-2 mb-0">@(Model.Title ?? "") @Model.FullName</h4>
                    <p class="opacity-75 mb-0">@(Model.PreferredName != null ? $"({Model.PreferredName})" : "")</p>
                    <small class="opacity-50">ID: @Model.SAIDNumber</small>
                </div>
                <div class="profile-body">
                    <div class="info-group">
                        <div class="info-label"><i class="fas fa-user-tie me-1"></i>Team Leader</div>
                        <div class="info-value"><a href="@Url.Action("Details","TeamLeader",new{id=Model.TeamLeaderId})">@Model.TeamLeader?.User?.FullName</a></div>
                    </div>
                    <div class="info-group">
                        <div class="info-label"><i class="fas fa-calendar me-1"></i>Date of Birth</div>
                        <div class="info-value">@(Model.DateOfBirth?.ToString("dd MMMM yyyy") ?? "—")</div>
                    </div>
                    <div class="info-group">
                        <div class="info-label"><i class="fas fa-venus-mars me-1"></i>Gender</div>
                        <div class="info-value">@Model.Gender</div>
                    </div>
                    @if (Model.Race.HasValue)
                    {
                        <div class="info-group">
                            <div class="info-label">Race</div>
                            <div class="info-value">@Model.Race</div>
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(Model.Nationality))
                    {
                        <div class="info-group">
                            <div class="info-label"><i class="fas fa-flag me-1"></i>Nationality</div>
                            <div class="info-value">@Model.Nationality</div>
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(Model.HomeLanguage))
                    {
                        <div class="info-group">
                            <div class="info-label"><i class="fas fa-language me-1"></i>Home Language</div>
                            <div class="info-value">@Model.HomeLanguage</div>
                        </div>
                    }
                    @if (Model.MaritalStatus.HasValue)
                    {
                        <div class="info-group">
                            <div class="info-label"><i class="fas fa-ring me-1"></i>Marital Status</div>
                            <div class="info-value">@Model.MaritalStatus</div>
                        </div>
                    }
                    <div class="info-group">
                        <div class="info-label">Registered</div>
                        <div class="info-value">@Model.CreatedAt.ToString("dd MMM yyyy")</div>
                    </div>
                    <div class="info-group">
                        <div class="info-label">Status</div>
                        <div class="info-value"><span class="badge @(Model.IsActive ? "bg-success" : "bg-secondary")">@(Model.IsActive ? "Active" : "Inactive")</span></div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Right: Tabs -->
        <div class="col-lg-8">
            <ul class="nav nav-tabs mb-3" role="tablist">
                <li class="nav-item"><a class="nav-link active" data-bs-toggle="tab" href="#tabContact"><i class="fas fa-phone me-1"></i>Contact</a></li>
                <li class="nav-item"><a class="nav-link" data-bs-toggle="tab" href="#tabAddress"><i class="fas fa-map-marker-alt me-1"></i>Address</a></li>
                <li class="nav-item"><a class="nav-link" data-bs-toggle="tab" href="#tabQualification"><i class="fas fa-graduation-cap me-1"></i>Qualification</a></li>
                <li class="nav-item"><a class="nav-link" data-bs-toggle="tab" href="#tabExperience"><i class="fas fa-briefcase me-1"></i>Experience</a></li>
                <li class="nav-item"><a class="nav-link" data-bs-toggle="tab" href="#tabNextOfKin"><i class="fas fa-users me-1"></i>Next of Kin</a></li>
                <li class="nav-item"><a class="nav-link" data-bs-toggle="tab" href="#tabBank"><i class="fas fa-university me-1"></i>Banking</a></li>
                <li class="nav-item"><a class="nav-link" data-bs-toggle="tab" href="#tabDocs"><i class="fas fa-file-alt me-1"></i>Documents</a></li>
                <li class="nav-item"><a class="nav-link" data-bs-toggle="tab" href="#tabPayroll"><i class="fas fa-money-bill me-1"></i>Payroll</a></li>
            </ul>

            <div class="tab-content">
                <!-- Contact Tab -->
                <div class="tab-pane fade show active" id="tabContact">
                    <div class="stat-card">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <div class="info-group">
                                    <div class="info-label"><i class="fas fa-envelope me-1"></i>Email</div>
                                    <div class="info-value"><a href="mailto:@Model.Email">@(Model.Email ?? "—")</a></div>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="info-group">
                                    <div class="info-label"><i class="fas fa-phone me-1"></i>Phone</div>
                                    <div class="info-value">@(Model.Phone ?? "—")</div>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="info-group">
                                    <div class="info-label"><i class="fas fa-phone-alt me-1"></i>Alternative Phone</div>
                                    <div class="info-value">@(Model.AlternativePhone ?? "—")</div>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="info-group">
                                    <div class="info-label"><i class="fab fa-whatsapp me-1 text-success"></i>WhatsApp</div>
                                    <div class="info-value">
                                        @if (!string.IsNullOrEmpty(Model.WhatsAppNumber))
                                        {
                                            <a href="https://wa.me/@Model.WhatsAppNumber?.Replace("+","").Replace(" ","")" target="_blank" class="text-success">@Model.WhatsAppNumber <i class="fas fa-external-link-alt ms-1 small"></i></a>
                                        }
                                        else { <span>—</span> }
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Address Tab -->
                <div class="tab-pane fade" id="tabAddress">
                    <div class="stat-card">
                        <h6 class="mb-3"><i class="fas fa-home me-2 text-primary"></i>Physical Address</h6>
                        <div class="row g-3">
                            <div class="col-md-12"><div class="info-group"><div class="info-label">Street Address</div><div class="info-value">@(Model.StreetAddress ?? "—")</div></div></div>
                            <div class="col-md-4"><div class="info-group"><div class="info-label">Suburb</div><div class="info-value">@(Model.Suburb ?? "—")</div></div></div>
                            <div class="col-md-4"><div class="info-group"><div class="info-label">City</div><div class="info-value">@(Model.City ?? "—")</div></div></div>
                            <div class="col-md-2"><div class="info-group"><div class="info-label">Province</div><div class="info-value">@(Model.Province?.ToString() ?? "—")</div></div></div>
                            <div class="col-md-2"><div class="info-group"><div class="info-label">Postal Code</div><div class="info-value">@(Model.PostalCode ?? "—")</div></div></div>
                        </div>
                        @if (!Model.SameAsPhysical && !string.IsNullOrEmpty(Model.PostalAddress))
                        {
                            <hr />
                            <h6 class="mb-3"><i class="fas fa-mail-bulk me-2 text-info"></i>Postal Address</h6>
                            <div class="row g-3">
                                <div class="col-md-12"><div class="info-group"><div class="info-label">Postal Address</div><div class="info-value">@(Model.PostalAddress ?? "—")</div></div></div>
                                <div class="col-md-4"><div class="info-group"><div class="info-label">City</div><div class="info-value">@(Model.PostalCity ?? "—")</div></div></div>
                                <div class="col-md-4"><div class="info-group"><div class="info-label">Province</div><div class="info-value">@(Model.PostalProvince?.ToString() ?? "—")</div></div></div>
                                <div class="col-md-4"><div class="info-group"><div class="info-label">Postal Code</div><div class="info-value">@(Model.PostalPostalCode ?? "—")</div></div></div>
                            </div>
                        }
                    </div>
                </div>

                <!-- Qualification Tab -->
                <div class="tab-pane fade" id="tabQualification">
                    <div class="stat-card">
                        <div class="row g-3">
                            <div class="col-md-4"><div class="info-group"><div class="info-label">Highest Grade</div><div class="info-value">@(Model.HighestGradePass ?? "—")</div></div></div>
                            <div class="col-md-4"><div class="info-group"><div class="info-label">Qualification Type</div><div class="info-value">@(Model.QualificationType ?? "—")</div></div></div>
                            <div class="col-md-4"><div class="info-group"><div class="info-label">Qualification Name</div><div class="info-value">@(Model.QualificationName ?? "—")</div></div></div>
                            <div class="col-md-4"><div class="info-group"><div class="info-label">Institution</div><div class="info-value">@(Model.Institution ?? "—")</div></div></div>
                            <div class="col-md-2"><div class="info-group"><div class="info-label">Year Completed</div><div class="info-value">@(Model.YearCompleted?.ToString() ?? "—")</div></div></div>
                            <div class="col-md-3"><div class="info-group"><div class="info-label">Student Number</div><div class="info-value">@(Model.StudentNumber ?? "—")</div></div></div>
                            @if (!string.IsNullOrEmpty(Model.OtherQualifications))
                            {
                                <div class="col-md-12"><div class="info-group"><div class="info-label">Other Qualifications</div><div class="info-value">@Model.OtherQualifications</div></div></div>
                            }
                        </div>
                    </div>
                </div>

                <!-- Experience Tab -->
                <div class="tab-pane fade" id="tabExperience">
                    <div class="stat-card">
                        <div class="row g-3">
                            <div class="col-md-4"><div class="info-group"><div class="info-label">Previous Employer</div><div class="info-value">@(Model.PreviousEmployer ?? "—")</div></div></div>
                            <div class="col-md-4"><div class="info-group"><div class="info-label">Job Title</div><div class="info-value">@(Model.PreviousJobTitle ?? "—")</div></div></div>
                            <div class="col-md-2"><div class="info-group"><div class="info-label">Years Exp.</div><div class="info-value">@(Model.YearsExperience?.ToString() ?? "—")</div></div></div>
                            @if (!string.IsNullOrEmpty(Model.WorkExperienceDescription))
                            {
                                <div class="col-md-12"><div class="info-group"><div class="info-label">Description</div><div class="info-value">@Model.WorkExperienceDescription</div></div></div>
                            }
                            @if (!string.IsNullOrEmpty(Model.Skills))
                            {
                                <div class="col-md-12"><div class="info-group"><div class="info-label">Skills</div><div class="info-value">@Model.Skills</div></div></div>
                            }
                            <div class="col-md-4"><div class="info-group"><div class="info-label">Driver's License</div><div class="info-value">@(Model.DriversLicense ?? "None")</div></div></div>
                            <div class="col-md-3"><div class="info-group"><div class="info-label">Own Transport</div><div class="info-value">@(Model.HasOwnTransport ? "Yes" : "No")</div></div></div>
                        </div>
                    </div>
                </div>

                <!-- Next of Kin Tab -->
                <div class="tab-pane fade" id="tabNextOfKin">
                    <div class="stat-card">
                        <div class="row g-3">
                            <div class="col-md-4"><div class="info-group"><div class="info-label">Full Name</div><div class="info-value">@(Model.NextOfKinName ?? "—")</div></div></div>
                            <div class="col-md-3"><div class="info-group"><div class="info-label">Relationship</div><div class="info-value">@(Model.NextOfKinRelationship ?? "—")</div></div></div>
                            <div class="col-md-3"><div class="info-group"><div class="info-label">Phone</div><div class="info-value">@(Model.NextOfKinPhone ?? "—")</div></div></div>
                            <div class="col-md-3"><div class="info-group"><div class="info-label">Alternative Phone</div><div class="info-value">@(Model.NextOfKinAlternativePhone ?? "—")</div></div></div>
                            <div class="col-md-3"><div class="info-group"><div class="info-label">Email</div><div class="info-value">@(Model.NextOfKinEmail ?? "—")</div></div></div>
                            @if (!string.IsNullOrEmpty(Model.NextOfKinAddress))
                            {
                                <div class="col-md-12"><div class="info-group"><div class="info-label">Address</div><div class="info-value">@Model.NextOfKinAddress</div></div></div>
                            }
                        </div>
                    </div>
                </div>

                <!-- Banking Tab -->
                <div class="tab-pane fade" id="tabBank">
                    <div class="stat-card">
                        <div class="row g-3">
                            <div class="col-md-4"><div class="info-group"><div class="info-label"><i class="fas fa-university me-1"></i>Bank</div><div class="info-value">@(Model.BankName ?? "—")</div></div></div>
                            <div class="col-md-4"><div class="info-group"><div class="info-label">Account Number</div><div class="info-value">@(Model.BankAccountNumber ?? "—")</div></div></div>
                            <div class="col-md-4"><div class="info-group"><div class="info-label">Account Type</div><div class="info-value">@(Model.AccountType ?? "—")</div></div></div>
                            <div class="col-md-4"><div class="info-group"><div class="info-label">Branch Code</div><div class="info-value">@(Model.BankBranchCode ?? "—")</div></div></div>
                            <div class="col-md-4"><div class="info-group"><div class="info-label">Branch Name</div><div class="info-value">@(Model.BranchName ?? "—")</div></div></div>
                            <div class="col-md-4"><div class="info-group"><div class="info-label">Account Holder</div><div class="info-value">@(Model.AccountHolderName ?? Model.FullName)</div></div></div>
                        </div>
                    </div>
                </div>

                <!-- Documents Tab -->
                <div class="tab-pane fade" id="tabDocs">
                    <div class="stat-card">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <h6 class="mb-0"><i class="fas fa-file-alt me-2"></i>Uploaded Documents</h6>
                            <button class="btn btn-sm btn-primary" data-bs-toggle="modal" data-bs-target="#uploadDocModal"><i class="fas fa-upload me-1"></i>Upload Document</button>
                        </div>
                        <div class="row g-3">
                            @foreach (var doc in Model.Documents)
                            {
                                <div class="col-md-6">
                                    <div class="doc-card has-file">
                                        <div class="d-flex align-items-center">
                                            <div class="me-3">
                                                @{
                                                    var icon = doc.DocumentType switch
                                                    {
                                                        Employeemanagementpractice.Models.DocumentType.IDCopy => "fa-id-card text-danger",
                                                        Employeemanagementpractice.Models.DocumentType.Qualification => "fa-graduation-cap text-warning",
                                                        Employeemanagementpractice.Models.DocumentType.BankStatement => "fa-file-invoice-dollar text-success",
                                                        _ => "fa-file text-secondary"
                                                    };
                                                }
                                                <i class="fas @icon fa-2x"></i>
                                            </div>
                                            <div class="text-start flex-grow-1">
                                                <div class="fw-bold small">@doc.DocumentType</div>
                                                <div class="text-muted small">@doc.OriginalFileName</div>
                                                <div class="text-muted small">@((doc.FileSize / 1024.0).ToString("N0")) KB &bull; @doc.UploadedAt.ToString("dd MMM yyyy")</div>
                                            </div>
                                            <div>
                                                <a href="@Url.Action("Download","Document",new{id=doc.Id})" class="btn btn-sm btn-outline-primary me-1" data-bs-toggle="tooltip" title="Download"><i class="fas fa-download"></i></a>
                                                <form asp-controller="Document" asp-action="Delete" method="post" class="d-inline">
                                                    <input type="hidden" name="id" value="@doc.Id" />
                                                    <input type="hidden" name="studentId" value="@Model.Id" />
                                                    <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('Delete this document?')" data-bs-toggle="tooltip" title="Delete"><i class="fas fa-trash"></i></button>
                                                </form>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            }
                            @if (!Model.Documents.Any())
                            {
                                <div class="col-12 text-center text-muted py-4">
                                    <i class="fas fa-folder-open fa-3x mb-3 d-block opacity-25"></i>
                                    No documents uploaded yet.
                                </div>
                            }
                        </div>
                    </div>
                </div>

                <!-- Payroll Tab -->
                <div class="tab-pane fade" id="tabPayroll">
                    <div class="stat-card">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <h6 class="mb-0"><i class="fas fa-money-bill-wave me-2"></i>Payment History</h6>
                            <a href="@Url.Action("Create","Payroll")" class="btn btn-sm btn-success"><i class="fas fa-plus me-1"></i>New Payment</a>
                        </div>
                        <table class="table table-hover mb-0" id="payrollTable">
                            <thead><tr><th>Date</th><th>Amount</th><th>Method</th><th>Reference</th><th>Status</th><th>Period</th></tr></thead>
                            <tbody>
                                @foreach (var p in Model.PayrollRecords.OrderByDescending(x => x.PaymentDate))
                                {
                                    var statusBadge = p.Status switch { Employeemanagementpractice.Models.PaymentStatus.Pending => "bg-warning", Employeemanagementpractice.Models.PaymentStatus.Paid => "bg-success", Employeemanagementpractice.Models.PaymentStatus.Failed => "bg-danger", _ => "bg-secondary" };
                                    <tr>
                                        <td>@p.PaymentDate.ToString("dd MMM yyyy")</td>
                                        <td class="fw-bold">R @p.Amount.ToString("N2")</td>
                                        <td>@(p.PaymentMethod ?? "—")</td>
                                        <td><small>@(p.Reference ?? "—")</small></td>
                                        <td><span class="badge @statusBadge badge-status">@p.Status</span></td>
                                        <td>@(p.PayPeriod ?? "—")</td>
                                    </tr>
                                }
                                @if (!Model.PayrollRecords.Any())
                                {
                                    <tr><td colspan="6" class="text-center text-muted py-3">No payment records.</td></tr>
                                }
                            </tbody>
                        </table>
                        @if (Model.PayrollRecords.Any())
                        {
                            <div class="border-top pt-3 d-flex justify-content-between">
                                <strong>Total: R @Model.PayrollRecords.Sum(p => p.Amount).ToString("N2")</strong>
                                <button class="btn btn-danger btn-sm" onclick="exportTableToPDF('payrollTable','Payroll - @Model.FullName')"><i class="fas fa-file-pdf me-1"></i>PDF</button>
                            </div>
                        }
                    </div>
                </div>
            </div>

            @if (!string.IsNullOrEmpty(Model.Notes))
            {
                <div class="stat-card mt-4">
                    <h6><i class="fas fa-sticky-note me-2"></i>Notes</h6>
                    <p class="text-muted">@Model.Notes</p>
                </div>
            }
        </div>
    </div>
</div>

<!-- Upload Document Modal -->
<div class="modal fade" id="uploadDocModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <form asp-controller="Document" asp-action="Upload" method="post" enctype="multipart/form-data">
                <div class="modal-header"><h5 class="modal-title"><i class="fas fa-upload me-2"></i>Upload Document</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
                <div class="modal-body">
                    <input type="hidden" name="studentId" value="@Model.Id" />
                    <div class="mb-3">
                        <label class="form-label fw-bold">Document Type</label>
                        <select name="documentType" class="form-select">
                            @foreach (var dt in Enum.GetValues<Employeemanagementpractice.Models.DocumentType>())
                            {
                                <option value="@((int)dt)">@dt</option>
                            }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">File</label>
                        <input type="file" name="file" class="form-control" required />
                    </div>
                </div>
                <div class="modal-footer"><button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button><button type="submit" class="btn btn-primary"><i class="fas fa-upload me-1"></i>Upload</button></div>
            </form>
        </div>
    </div>
</div>
