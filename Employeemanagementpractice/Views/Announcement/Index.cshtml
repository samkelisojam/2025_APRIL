@model List<Employeemanagementpractice.Models.Announcement>
@{
    ViewData["Title"] = "Announcements";
    var canCreate = ViewBag.CanCreate == true;
    var canDelete = User.IsInRole("Admin") || User.IsInRole("Manager");
}

<div class="fade-in">
    <div class="page-header">
        <h2 style="font-size:1.1rem;"><i class="fas fa-bullhorn me-2"></i>Announcements</h2>
        @if (canCreate)
        {
            <a href="@Url.Action("Create")" class="btn btn-primary btn-sm"><i class="fas fa-plus me-1"></i>New Announcement</a>
        }
    </div>

    <div class="row g-3">
        @foreach (var ann in Model)
        {
            var audienceBadge = ann.TargetAudience switch {
                Employeemanagementpractice.Models.TargetAudience.All => "bg-primary",
                Employeemanagementpractice.Models.TargetAudience.TeamLeaders => "bg-info",
                Employeemanagementpractice.Models.TargetAudience.Staff => "bg-warning text-dark",
                _ => "bg-secondary"
            };
            <div class="col-md-6">
                <div class="stat-card">
                    <div class="d-flex justify-content-between align-items-start mb-2">
                        <h6 class="mb-0" style="font-size:0.85rem;"><i class="fas fa-bullhorn me-2 text-warning"></i>@ann.Title</h6>
                        <span class="badge @audienceBadge" style="font-size:0.65rem;">@ann.TargetAudience</span>
                    </div>
                    <p class="text-muted" style="font-size:0.78rem;">@ann.Message</p>
                    <div class="d-flex justify-content-between align-items-center">
                        <small class="text-muted" style="font-size:0.68rem;">
                            <i class="fas fa-user me-1"></i>@ann.CreatedBy?.FullName &bull;
                            <i class="fas fa-clock me-1"></i>@ann.CreatedAt.ToString("dd MMM yyyy HH:mm")
                            @if (ann.ExpiresAt.HasValue) { <span>&bull; Expires: @ann.ExpiresAt.Value.ToString("dd MMM yyyy")</span> }
                        </small>
                        @if (canDelete)
                        {
                            <form asp-action="Delete" method="post" class="d-inline">
                                <input type="hidden" name="id" value="@ann.Id" />
                                <button type="submit" class="btn btn-sm btn-outline-danger" style="font-size:0.7rem;padding:2px 6px;" onclick="return confirm('Remove this announcement?')"><i class="fas fa-trash"></i></button>
                            </form>
                        }
                    </div>
                </div>
            </div>
        }
        @if (!Model.Any())
        {
            <div class="col-12 text-center text-muted py-4" style="font-size:0.8rem;">
                <i class="fas fa-bullhorn fa-2x mb-2 d-block opacity-25"></i>
                No announcements.
                @if (canCreate) { <a href="@Url.Action("Create")">Create one now</a> }
            </div>
        }
    </div>

    @if ((int)ViewBag.TotalPages > 1)
    {
        <nav class="mt-3"><ul class="pagination pagination-sm justify-content-center">
            @for (int i = 1; i <= (int)ViewBag.TotalPages; i++)
            {
                <li class="page-item @(i == (int)ViewBag.Page ? "active" : "")"><a class="page-link" href="@Url.Action("Index",new{page=i})">@i</a></li>
            }
        </ul></nav>
    }
</div>
