@{ ViewData["Title"] = "Help Center"; }

<h4 class="fw-bold mb-4"><i class="fas fa-question-circle text-primary me-2"></i>Help Center</h4>

<div class="row g-4">
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-header bg-primary text-white fw-bold"><i class="fas fa-search me-1"></i>How can we help?</div>
            <div class="card-body">
                <input type="text" class="form-control form-control-lg" id="helpSearch" placeholder="Search help topics..." />
            </div>
        </div>

        <div class="accordion" id="faqAccordion">
            <div class="accordion-item border-0 shadow-sm mb-2" data-topic="getting started login">
                <h2 class="accordion-header"><button class="accordion-button collapsed" data-bs-toggle="collapse" data-bs-target="#faq1"><i class="fas fa-sign-in-alt text-primary me-2"></i>How do I log in?</button></h2>
                <div id="faq1" class="accordion-collapse collapse" data-bs-parent="#faqAccordion"><div class="accordion-body">Use your registered email and password on the Login page. If you've forgotten your password, contact your Admin. Default admin: <strong>admin@system.co.za</strong></div></div>
            </div>
            <div class="accordion-item border-0 shadow-sm mb-2" data-topic="student add register employee">
                <h2 class="accordion-header"><button class="accordion-button collapsed" data-bs-toggle="collapse" data-bs-target="#faq2"><i class="fas fa-user-plus text-success me-2"></i>How do I add a new student/employee?</button></h2>
                <div id="faq2" class="accordion-collapse collapse" data-bs-parent="#faqAccordion"><div class="accordion-body">Navigate to <strong>Students &rarr; Create New</strong>. Fill in all required fields including SA ID Number (validated automatically), personal details, program information, and assign a Team Leader. Click Save to register.</div></div>
            </div>
            <div class="accordion-item border-0 shadow-sm mb-2" data-topic="task assign create manage">
                <h2 class="accordion-header"><button class="accordion-button collapsed" data-bs-toggle="collapse" data-bs-target="#faq3"><i class="fas fa-tasks text-info me-2"></i>How do I manage tasks?</button></h2>
                <div id="faq3" class="accordion-collapse collapse" data-bs-parent="#faqAccordion"><div class="accordion-body">Go to <strong>Tasks</strong> page to view all tasks. Click <strong>Create New Task</strong> to assign tasks with title, description, priority, due date, and assigned user. Update status as tasks progress: Pending &rarr; InProgress &rarr; Completed.</div></div>
            </div>
            <div class="accordion-item border-0 shadow-sm mb-2" data-topic="payroll salary payment">
                <h2 class="accordion-header"><button class="accordion-button collapsed" data-bs-toggle="collapse" data-bs-target="#faq4"><i class="fas fa-money-bill-wave text-warning me-2"></i>How does payroll work?</button></h2>
                <div id="faq4" class="accordion-collapse collapse" data-bs-parent="#faqAccordion"><div class="accordion-body">Navigate to <strong>Payroll &rarr; Create</strong>. Select the student/employee, enter basic salary, deductions, and bonus. The net pay is calculated automatically. Records can be exported to Excel or PDF.</div></div>
            </div>
            <div class="accordion-item border-0 shadow-sm mb-2" data-topic="report export generate pdf excel">
                <h2 class="accordion-header"><button class="accordion-button collapsed" data-bs-toggle="collapse" data-bs-target="#faq5"><i class="fas fa-file-alt text-danger me-2"></i>How do I generate reports?</button></h2>
                <div id="faq5" class="accordion-collapse collapse" data-bs-parent="#faqAccordion"><div class="accordion-body">Go to <strong>Reports</strong>. Use the Report Builder to select entity type, columns, and filters. Export as <strong>PDF</strong> or <strong>Excel</strong>. Saved reports can be loaded later.</div></div>
            </div>
            <div class="accordion-item border-0 shadow-sm mb-2" data-topic="role permission admin manager team leader staff">
                <h2 class="accordion-header"><button class="accordion-button collapsed" data-bs-toggle="collapse" data-bs-target="#faq6"><i class="fas fa-shield-alt text-secondary me-2"></i>What are the user roles?</button></h2>
                <div id="faq6" class="accordion-collapse collapse" data-bs-parent="#faqAccordion"><div class="accordion-body"><ul class="mb-0"><li><strong>Admin</strong> – Full access to all features, settings, backups, and user management</li><li><strong>Manager</strong> – Manage students, tasks, payroll, reports; limited admin settings</li><li><strong>Team Leader</strong> – View and manage assigned students; create tasks</li><li><strong>Staff</strong> – View data, limited editing capabilities</li><li><strong>ReadOnly</strong> – View-only access for auditors</li></ul></div></div>
            </div>
            <div class="accordion-item border-0 shadow-sm mb-2" data-topic="training course learn">
                <h2 class="accordion-header"><button class="accordion-button collapsed" data-bs-toggle="collapse" data-bs-target="#faq7"><i class="fas fa-chalkboard-teacher text-primary me-2"></i>How do I access training?</button></h2>
                <div id="faq7" class="accordion-collapse collapse" data-bs-parent="#faqAccordion"><div class="accordion-body">Navigate to <strong>Training</strong> in the sidebar. Browse available courses by category when you find one click <strong>Start Course</strong>. Track your progress and complete quizzes. Admins/Managers can create new courses.</div></div>
            </div>
            <div class="accordion-item border-0 shadow-sm mb-2" data-topic="backup database restore">
                <h2 class="accordion-header"><button class="accordion-button collapsed" data-bs-toggle="collapse" data-bs-target="#faq8"><i class="fas fa-database text-success me-2"></i>How are backups managed?</button></h2>
                <div id="faq8" class="accordion-collapse collapse" data-bs-parent="#faqAccordion"><div class="accordion-body">Admins can create backups from <strong>Admin &rarr; Backup</strong>. Choose Full Database backup (SQL Server) or Excel export. Backups are stored securely and can be downloaded. Monthly automatic backups are recommended.</div></div>
            </div>
            <div class="accordion-item border-0 shadow-sm mb-2" data-topic="import batch excel upload csv">
                <h2 class="accordion-header"><button class="accordion-button collapsed" data-bs-toggle="collapse" data-bs-target="#faq9"><i class="fas fa-file-import text-info me-2"></i>Can I bulk import students?</button></h2>
                <div id="faq9" class="accordion-collapse collapse" data-bs-parent="#faqAccordion"><div class="accordion-body">Yes! Go to <strong>Admin &rarr; Import</strong>. Download the Excel template, fill in student data, and upload. The system validates SA ID numbers and checks for duplicates automatically.</div></div>
            </div>
            <div class="accordion-item border-0 shadow-sm mb-2" data-topic="attendance track check mark present absent">
                <h2 class="accordion-header"><button class="accordion-button collapsed" data-bs-toggle="collapse" data-bs-target="#faq10"><i class="fas fa-user-check text-success me-2"></i>How does attendance tracking work?</button></h2>
                <div id="faq10" class="accordion-collapse collapse" data-bs-parent="#faqAccordion"><div class="accordion-body">Navigate to <strong>Attendance</strong>. Select a date, then mark each student's status (Present, Absent, Late, Excused, Half Day). Use Bulk Mark for quick updates. View attendance statistics and trends over time.</div></div>
            </div>
        </div>
    </div>
    <div class="col-lg-4">
        <div class="card border-0 shadow-sm mb-3">
            <div class="card-header bg-white fw-bold"><i class="fas fa-keyboard me-1"></i>Keyboard Shortcuts</div>
            <div class="card-body p-0">
                <table class="table table-sm mb-0">
                    <tr><td><kbd>Ctrl</kbd>+<kbd>/</kbd></td><td>Global Search</td></tr>
                    <tr><td><kbd>Ctrl</kbd>+<kbd>N</kbd></td><td>New Record</td></tr>
                    <tr><td><kbd>Esc</kbd></td><td>Close Modal/Dialog</td></tr>
                </table>
            </div>
        </div>
        <div class="card border-0 shadow-sm mb-3">
            <div class="card-header bg-white fw-bold"><i class="fas fa-headset me-1"></i>Need More Help?</div>
            <div class="card-body">
                <p class="text-muted">Contact your system administrator for:</p>
                <ul>
                    <li>Account issues & password resets</li>
                    <li>Permission changes</li>
                    <li>Technical support</li>
                    <li>Feature requests</li>
                </ul>
                <a href="mailto:admin@system.co.za" class="btn btn-outline-primary w-100"><i class="fas fa-envelope me-1"></i>Email Support</a>
            </div>
        </div>
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white fw-bold"><i class="fas fa-code me-1"></i>System Version</div>
            <div class="card-body">
                <p class="mb-1"><strong>Version:</strong> 2.0.0</p>
                <p class="mb-1"><strong>Framework:</strong> ASP.NET Core 8.0</p>
                <p class="mb-1"><strong>Database:</strong> SQL Server</p>
                <p class="mb-0"><strong>Real-time:</strong> SignalR</p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
document.getElementById('helpSearch').addEventListener('input', function() {
    const q = this.value.toLowerCase();
    document.querySelectorAll('.accordion-item').forEach(item => {
        const topic = (item.dataset.topic || '') + ' ' + item.textContent.toLowerCase();
        item.style.display = !q || topic.includes(q) ? '' : 'none';
    });
});
</script>
}
