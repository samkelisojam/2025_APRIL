@model List<Employeemanagementpractice.Models.UserActivity>
@{ ViewData["Title"] = "Staff Activity Log"; }

<div class="fade-in">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 class="fw-bold mb-0"><i class="fas fa-user-clock text-primary me-2"></i>Staff Activity Log</h4>
        <div class="btn-group">
            <button class="btn btn-outline-primary btn-sm active" id="btnTable" onclick="showTab('table')"><i class="fas fa-table me-1"></i>Table</button>
            <button class="btn btn-outline-primary btn-sm" id="btnTimeline" onclick="showTab('timeline')"><i class="fas fa-stream me-1"></i>Live Feed</button>
            <button class="btn btn-outline-primary btn-sm" id="btnStats" onclick="showTab('stats')"><i class="fas fa-chart-bar me-1"></i>Analytics</button>
        </div>
    </div>

    <!-- Stats Bar -->
    <div class="row g-3 mb-4 slide-up">
        <div class="col-md-2"><div class="stat-card text-center py-3"><div class="stat-icon mx-auto mb-2" style="background:#dbeafe;color:#0d6efd;width:40px;height:40px;border-radius:10px;display:flex;align-items:center;justify-content:center;"><i class="fas fa-eye"></i></div><div class="fs-4 fw-bold text-primary" id="statTotal">@ViewBag.TotalCount</div><small class="text-muted">Total Activities</small></div></div>
        <div class="col-md-2"><div class="stat-card text-center py-3"><div class="stat-icon mx-auto mb-2" style="background:#dcfce7;color:#16a34a;width:40px;height:40px;border-radius:10px;display:flex;align-items:center;justify-content:center;"><i class="fas fa-sign-in-alt"></i></div><div class="fs-4 fw-bold text-success" id="statLogins">0</div><small class="text-muted">Logins</small></div></div>
        <div class="col-md-2"><div class="stat-card text-center py-3"><div class="stat-icon mx-auto mb-2" style="background:#fef3c7;color:#d97706;width:40px;height:40px;border-radius:10px;display:flex;align-items:center;justify-content:center;"><i class="fas fa-file-alt"></i></div><div class="fs-4 fw-bold text-warning" id="statViews">0</div><small class="text-muted">Page Views</small></div></div>
        <div class="col-md-2"><div class="stat-card text-center py-3"><div class="stat-icon mx-auto mb-2" style="background:#fce7f3;color:#db2777;width:40px;height:40px;border-radius:10px;display:flex;align-items:center;justify-content:center;"><i class="fas fa-download"></i></div><div class="fs-4 fw-bold text-danger" id="statDownloads">0</div><small class="text-muted">Downloads</small></div></div>
        <div class="col-md-2"><div class="stat-card text-center py-3"><div class="stat-icon mx-auto mb-2" style="background:#e0e7ff;color:#4f46e5;width:40px;height:40px;border-radius:10px;display:flex;align-items:center;justify-content:center;"><i class="fas fa-users"></i></div><div class="fs-4 fw-bold" style="color:#4f46e5;" id="statUsers">0</div><small class="text-muted">Active Users</small></div></div>
        <div class="col-md-2"><div class="stat-card text-center py-3"><div class="stat-icon mx-auto mb-2" style="background:#f0fdf4;color:#22c55e;width:40px;height:40px;border-radius:10px;display:flex;align-items:center;justify-content:center;"><i class="fas fa-file-export"></i></div><div class="fs-4 fw-bold text-success" id="statExports">0</div><small class="text-muted">Exports</small></div></div>
    </div>

    <!-- TABLE VIEW -->
    <div id="viewTable">
        <!-- Filter Bar -->
        <div class="filter-bar mb-3 slide-up" style="animation-delay:0.1s;">
            <form method="get" class="row g-2 align-items-end no-loading">
                <div class="col-md-3">
                    <div class="input-group input-group-sm">
                        <span class="input-group-text bg-white"><i class="fas fa-search text-muted"></i></span>
                        <input type="text" name="search" class="form-control" placeholder="Search user, description, page..." value="@ViewBag.Search" />
                    </div>
                </div>
                <div class="col-md-2">
                    <select name="activityType" class="form-select form-select-sm">
                        <option value="">All Types</option>
                        @foreach (var t in new[] { "Login", "Logout", "PageView", "Download", "Create", "Edit", "Delete", "Export" })
                        {
                            <option value="@t" selected="@(ViewBag.ActivityType == t)">@t</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <select name="userId" class="form-select form-select-sm">
                        <option value="">All Users</option>
                        @foreach (var u in ViewBag.Users as List<Employeemanagementpractice.Models.ApplicationUser>)
                        {
                            <option value="@u.Id" selected="@(ViewBag.UserId == u.Id)">@u.FullName</option>
                        }
                    </select>
                </div>
                <div class="col-md-2"><input type="date" name="from" class="form-control form-control-sm" value="@ViewBag.From" placeholder="From" /></div>
                <div class="col-md-1"><input type="date" name="to" class="form-control form-control-sm" value="@ViewBag.To" placeholder="To" /></div>
                <div class="col-md-1"><button type="submit" class="btn btn-primary btn-sm w-100"><i class="fas fa-filter"></i></button></div>
                <div class="col-md-1"><a href="/Activity" class="btn btn-outline-secondary btn-sm w-100"><i class="fas fa-times"></i></a></div>
            </form>
        </div>

        <div class="table-container slide-up" style="animation-delay:0.15s;">
            <table class="table table-hover mb-0" id="activityTable">
                <thead>
                    <tr>
                        <th style="width:40px;"></th>
                        <th>User</th>
                        <th>Activity</th>
                        <th>Description</th>
                        <th>Page / URL</th>
                        <th>Browser</th>
                        <th>IP</th>
                        <th>When</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var a in Model)
                    {
                        var iconClass = a.ActivityType switch {
                            "Login" => "fa-sign-in-alt text-success",
                            "Logout" => "fa-sign-out-alt text-secondary",
                            "PageView" => "fa-eye text-primary",
                            "Download" => "fa-download text-danger",
                            "Create" => "fa-plus-circle text-success",
                            "Edit" => "fa-edit text-warning",
                            "Delete" => "fa-trash text-danger",
                            "Export" => "fa-file-export text-info",
                            _ => "fa-circle text-muted"
                        };
                        var rowClass = a.ActivityType switch {
                            "Login" => "activity-login",
                            "Logout" => "activity-logout",
                            "Download" => "activity-download",
                            _ => ""
                        };
                        var roleColor = a.Role switch {
                            "Admin" => "danger",
                            "Manager" => "primary",
                            "TeamLeader" => "warning",
                            "Staff" => "info",
                            _ => "secondary"
                        };
                        <tr class="@rowClass fade-in-row">
                            <td class="text-center"><i class="fas @iconClass"></i></td>
                            <td>
                                <div class="fw-semibold small">@(a.FullName ?? a.UserName ?? "Unknown")</div>
                                <span class="badge bg-@roleColor" style="font-size:0.6rem;">@(a.Role ?? "—")</span>
                            </td>
                            <td><span class="badge bg-@(a.ActivityType == "Login" ? "success" : a.ActivityType == "Download" ? "danger" : a.ActivityType == "Logout" ? "secondary" : a.ActivityType == "PageView" ? "primary" : "info") bg-opacity-75">@a.ActivityType</span></td>
                            <td class="small text-muted" style="max-width:250px;">@(a.Description?.Length > 60 ? a.Description.Substring(0, 60) + "..." : a.Description ?? "—")</td>
                            <td class="small"><code class="text-muted">@(a.PageUrl ?? "—")</code></td>
                            <td class="small">
                                @{ var bIcon = (a.Browser ?? "") switch { "Chrome" => "fa-brands fa-chrome", "Edge" => "fa-brands fa-edge", "Firefox" => "fa-brands fa-firefox", "Safari" => "fa-brands fa-safari", _ => "fas fa-globe" }; }
                                <i class="@bIcon me-1"></i>@(a.Browser ?? "—")
                            </td>
                            <td class="small text-nowrap">@(a.IpAddress ?? "—")</td>
                            <td class="small text-nowrap" title="@a.Timestamp.ToString("yyyy-MM-dd HH:mm:ss")">
                                <span data-timestamp="@a.Timestamp.ToString("o")">@a.Timestamp.ToString("dd MMM HH:mm")</span>
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr><td colspan="8" class="text-center text-muted py-5">
                            <i class="fas fa-user-clock fa-3x mb-3 d-block opacity-25"></i>
                            No activity recorded yet. Staff activities will appear here.
                        </td></tr>
                    }
                </tbody>
            </table>

            @if ((int)ViewBag.TotalPages > 1)
            {
                <div class="pagination-wrapper">
                    <span class="text-muted small">Page @ViewBag.Page of @ViewBag.TotalPages (@ViewBag.TotalCount total)</span>
                    <nav>
                        <ul class="pagination pagination-sm mb-0">
                            @for (int i = 1; i <= (int)ViewBag.TotalPages; i++)
                            {
                                <li class="page-item @(i == (int)ViewBag.Page ? "active" : "")">
                                    <a class="page-link" href="@Url.Action("Index", new { page = i, search = ViewBag.Search, activityType = ViewBag.ActivityType, userId = ViewBag.UserId, from = ViewBag.From, to = ViewBag.To })">@i</a>
                                </li>
                            }
                        </ul>
                    </nav>
                </div>
            }
        </div>

        <div class="mt-3">
            <button class="btn btn-danger btn-sm" onclick="exportTableToPDF('activityTable','Staff Activity Log')"><i class="fas fa-file-pdf me-1"></i>Export PDF</button>
        </div>
    </div>

    <!-- TIMELINE VIEW -->
    <div id="viewTimeline" class="d-none">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white d-flex justify-content-between align-items-center">
                <span class="fw-bold"><i class="fas fa-stream me-1"></i>Live Activity Feed</span>
                <button class="btn btn-sm btn-outline-primary" onclick="loadTimeline()"><i class="fas fa-sync-alt me-1"></i>Refresh</button>
            </div>
            <div class="card-body p-0" id="timelineBody" style="max-height:600px;overflow-y:auto;">
                <div class="text-center py-4 text-muted"><i class="fas fa-spinner fa-spin"></i> Loading feed...</div>
            </div>
        </div>
    </div>

    <!-- STATS VIEW -->
    <div id="viewStats" class="d-none">
        <div class="row g-4">
            <div class="col-lg-6">
                <div class="card border-0 shadow-sm">
                    <div class="card-header bg-white fw-bold"><i class="fas fa-trophy text-warning me-1"></i>Most Active Users</div>
                    <div class="card-body p-0">
                        <table class="table table-hover mb-0">
                            <thead class="table-light"><tr><th>#</th><th>User</th><th>Role</th><th>Activities</th><th>Last Active</th></tr></thead>
                            <tbody id="topUsersTable"><tr><td colspan="5" class="text-center text-muted py-3">Loading...</td></tr></tbody>
                        </table>
                    </div>
                </div>
            </div>
            <div class="col-lg-6">
                <div class="card border-0 shadow-sm">
                    <div class="card-header bg-white fw-bold"><i class="fas fa-chart-pie text-info me-1"></i>Activity Breakdown</div>
                    <div class="card-body" id="activityBreakdown">
                        <div class="text-center text-muted py-3">Loading...</div>
                    </div>
                </div>
            </div>
            <div class="col-12">
                <div class="card border-0 shadow-sm">
                    <div class="card-header bg-white fw-bold"><i class="fas fa-clock text-primary me-1"></i>Activity by Hour of Day</div>
                    <div class="card-body" id="hourlyChart">
                        <div class="text-center text-muted py-3">Loading...</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
// Load stats on page load
loadStats();

function showTab(tab) {
    document.getElementById('viewTable').classList.toggle('d-none', tab !== 'table');
    document.getElementById('viewTimeline').classList.toggle('d-none', tab !== 'timeline');
    document.getElementById('viewStats').classList.toggle('d-none', tab !== 'stats');
    document.getElementById('btnTable').classList.toggle('active', tab === 'table');
    document.getElementById('btnTimeline').classList.toggle('active', tab === 'timeline');
    document.getElementById('btnStats').classList.toggle('active', tab === 'stats');
    if (tab === 'timeline') loadTimeline();
    if (tab === 'stats') loadStats();
}

async function loadStats() {
    try {
        const res = await fetch('/Activity/Stats');
        const s = await res.json();
        document.getElementById('statLogins').textContent = s.logins || 0;
        document.getElementById('statViews').textContent = s.pageViews || 0;
        document.getElementById('statDownloads').textContent = s.downloads || 0;
        document.getElementById('statUsers').textContent = s.uniqueUsers || 0;
        document.getElementById('statExports').textContent = s.exports || 0;

        // Top users
        if (s.topUsers && s.topUsers.length) {
            const roleColors = { Admin:'danger', Manager:'primary', TeamLeader:'warning', Staff:'info' };
            document.getElementById('topUsersTable').innerHTML = s.topUsers.map((u, i) => {
                const rc = roleColors[u.role] || 'secondary';
                return `<tr class="fade-in-row" style="animation-delay:${i*0.05}s"><td class="fw-bold">${i+1}</td><td class="fw-semibold">${u.fullName||'Unknown'}</td><td><span class="badge bg-${rc}">${u.role||'—'}</span></td><td><span class="fw-bold text-primary">${u.count}</span></td><td class="small text-muted">${u.lastActive ? new Date(u.lastActive).toLocaleString('en-ZA') : '—'}</td></tr>`;
            }).join('');
        }

        // Activity breakdown
        if (s.byType && s.byType.length) {
            const typeColors = { Login:'#22c55e', Logout:'#94a3b8', PageView:'#0d6efd', Download:'#ef4444', Create:'#8b5cf6', Edit:'#f59e0b', Delete:'#dc2626', Export:'#06b6d4' };
            const max = Math.max(...s.byType.map(t => t.count));
            document.getElementById('activityBreakdown').innerHTML = s.byType.map(t => {
                const pct = Math.round(t.count / max * 100);
                const c = typeColors[t.type] || '#64748b';
                return `<div class="d-flex align-items-center mb-2"><div style="width:100px;" class="small fw-semibold">${t.type}</div><div class="flex-grow-1"><div class="progress" style="height:24px;"><div class="progress-bar" style="width:${pct}%;background:${c};">${t.count}</div></div></div></div>`;
            }).join('');
        }

        // Hourly chart
        if (s.byHour && s.byHour.length) {
            const maxH = Math.max(...s.byHour.map(h => h.count), 1);
            let hourMap = {};
            s.byHour.forEach(h => hourMap[h.hour] = h.count);
            let bars = '';
            for (let h = 0; h < 24; h++) {
                const count = hourMap[h] || 0;
                const height = Math.max(count / maxH * 120, 2);
                const isWork = h >= 8 && h <= 17;
                bars += `<div class="d-flex flex-column align-items-center" style="flex:1;"><div style="height:${height}px;width:100%;max-width:30px;background:${isWork?'#0d6efd':'#e2e8f0'};border-radius:4px 4px 0 0;" title="${count} activities"></div><small class="text-muted" style="font-size:0.6rem;">${h}:00</small></div>`;
            }
            document.getElementById('hourlyChart').innerHTML = `<div class="d-flex align-items-end gap-1" style="height:150px;">${bars}</div><div class="text-center mt-2"><small class="text-muted"><span class="badge bg-primary me-1">&nbsp;</span>Work hours (8-17) <span class="badge bg-light text-dark ms-2 me-1">&nbsp;</span>Off hours</small></div>`;
        }
    } catch(e) { console.log('Stats error', e); }
}

async function loadTimeline() {
    const body = document.getElementById('timelineBody');
    try {
        const res = await fetch('/Activity/Timeline?count=80');
        const items = await res.json();
        if (!items.length) { body.innerHTML = '<div class="text-center py-4 text-muted">No recent activity</div>'; return; }
        
        const typeIcons = { Login:'fa-sign-in-alt text-success', Logout:'fa-sign-out-alt text-secondary', PageView:'fa-eye text-primary', Download:'fa-download text-danger', Create:'fa-plus-circle text-success', Edit:'fa-edit text-warning', Delete:'fa-trash text-danger', Export:'fa-file-export text-info' };
        const roleColors = { Admin:'danger', Manager:'primary', TeamLeader:'warning', Staff:'info', ReadOnly:'secondary' };
        
        let lastDate = '';
        body.innerHTML = items.map((a, i) => {
            const d = new Date(a.timestamp);
            const dateStr = d.toLocaleDateString('en-ZA', {weekday:'long', year:'numeric', month:'long', day:'numeric'});
            const time = d.toLocaleTimeString('en-ZA', {hour:'2-digit', minute:'2-digit'});
            const icon = typeIcons[a.activityType] || 'fa-circle text-muted';
            const rc = roleColors[a.role] || 'secondary';
            
            let dateHeader = '';
            if (dateStr !== lastDate) { lastDate = dateStr; dateHeader = `<div class="px-3 py-2 bg-light border-bottom"><small class="fw-bold text-muted text-uppercase"><i class="fas fa-calendar-day me-1"></i>${dateStr}</small></div>`; }
            
            return dateHeader + `<div class="d-flex align-items-start p-3 border-bottom timeline-item fade-in-row" style="animation-delay:${Math.min(i*0.03, 1)}s">
                <div class="rounded-circle bg-light d-flex align-items-center justify-content-center me-3" style="width:36px;height:36px;min-width:36px;"><i class="fas ${icon}"></i></div>
                <div class="flex-grow-1">
                    <div class="d-flex justify-content-between"><div><strong class="small">${a.fullName||'Unknown'}</strong> <span class="badge bg-${rc}" style="font-size:0.55rem;">${a.role||''}</span></div><small class="text-muted">${time}</small></div>
                    <div class="small text-muted mt-1">${a.description||a.activityType}</div>
                    ${a.pageUrl ? `<code class="small text-muted">${a.pageUrl}</code>` : ''}
                    ${a.browser ? `<span class="small text-muted ms-2"><i class="fas fa-globe me-1"></i>${a.browser}</span>` : ''}
                </div>
            </div>`;
        }).join('');
    } catch(e) { body.innerHTML = '<div class="text-center py-4 text-danger">Error loading feed</div>'; }
}
</script>
}
